# App
KAIJU_BASE_URL=https://your-tenant.kaiju.io

# Credentials
KAIJU_EMAIL=your@email.com
KAIJU_PASSWORD=your_password

# 2FA — base32 secret from your authenticator app setup screen
KAIJU_TOTP_SECRET=YOUR_BASE32_SECRET

# API — public test API (swap for real API URL when access is available)
KAIJU_API_BASE_URL=https://mytestapi.com

# Browser
HEADLESS=true
